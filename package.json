{
  "name": "playbookops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable playbooks for teams that ship with evidence.",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --config site/prompt-explorer/vite.config.ts",
    "build": "tsc -p site/prompt-explorer/tsconfig.json && vite build --config site/prompt-explorer/vite.config.ts",
    "preview": "vite preview --config site/prompt-explorer/vite.config.ts",
    "validate:catalog": "tsx tools/validate-catalog.ts",
    "generate:agents": "tsx tools/generate-agents-md.ts",
    "generate:claude": "tsx tools/generate-claude-md.ts",
    "generate:kiro-steering": "tsx tools/generate-kiro-steering.ts",
    "generate:kiro-spec": "tsx tools/generate-kiro-spec.ts",
    "generate:cursor": "tsx tools/generate-cursor-rules.ts",
    "generate:windsurf": "tsx tools/generate-windsurf-rules.ts",
    "generate:copilot": "tsx tools/generate-copilot-instructions.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "ajv": "^8.17.1",
    "lucide-react": "^0.468.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
